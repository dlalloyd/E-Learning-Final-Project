// Prisma Schema - Adaptive E-Learning System
// Updated: IRT 3PL + BKT architecture (ADR-001, ADR-003, ADR-004)
// Replaces Elo-based difficulty field with IRT parameters (a, b, c)

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

// ─── User ─────────────────────────────────────────────────────────────────────

model User {
  id        String   @id @default(cuid())
  email     String   @unique
  name      String
  password  String
  role      String   @default("learner") // learner, instructor, admin
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  sessions        Session[]
  assessments     Assessment[]
  progress        UserProgress[]
  badges          UserBadge[]
  variantsSeen    UserVariantSeen[]
  studySchedules  StudySchedule[]
  goals           LearnerGoal[]
  researchConsent ResearchConsent?
}

// ─── Topic / Lesson / Quiz ────────────────────────────────────────────────────

model Topic {
  id          String   @id @default(cuid())
  title       String
  description String?
  order       Int
  createdAt   DateTime @default(now())

  lessons       Lesson[]
  prerequisites TopicPrerequisite[] @relation("topic_prereqs")
  requiredFor   TopicPrerequisite[] @relation("topic_required_for")
}

model TopicPrerequisite {
  topicId        String
  prerequisiteId String
  topic          Topic  @relation("topic_required_for", fields: [topicId], references: [id], onDelete: Cascade)
  prerequisite   Topic  @relation("topic_prereqs", fields: [prerequisiteId], references: [id], onDelete: Cascade)

  @@id([topicId, prerequisiteId])
}

model Lesson {
  id        String   @id @default(cuid())
  title     String
  content   String
  topicId   String
  order     Int
  createdAt DateTime @default(now())

  topic   Topic  @relation(fields: [topicId], references: [id], onDelete: Cascade)
  quizzes Quiz[]
}

model Quiz {
  id        String   @id @default(cuid())
  title     String
  lessonId  String
  createdAt DateTime @default(now())

  lesson      Lesson       @relation(fields: [lessonId], references: [id], onDelete: Cascade)
  questions   Question[]
  assessments Assessment[]
  sessions    Session[]
}

// ─── Question (IRT 3PL parameters) ───────────────────────────────────────────

model Question {
  id        String   @id @default(cuid())
  text      String
  type      String   @default("multiple_choice")
  quizId    String
  order     Int
  hint      Hint[]
  createdAt DateTime @default(now())

  // IRT 3PL parameters (replaces Elo difficulty field)
  // a = discrimination (0.5–2.0), b = difficulty (logits), c = guessing (fixed 0.25)
  irt_a Float @default(1.0) // discrimination
  irt_b Float @default(0.0) // difficulty in logits
  irt_c Float @default(0.25) // guessing (fixed for 4-option MCQ)

  // Bloom's taxonomy level and knowledge component
  bloom Int    @default(1) // 1=Remembering, 2=Understanding, 3=Applying
  kc    String @default("") // knowledge component ID (matches BKT params)

  quiz         Quiz          @relation(fields: [quizId], references: [id], onDelete: Cascade)
  options      Option[]
  answers      Answer[]
  interactions Interaction[]
}

model Option {
  id         String  @id @default(cuid())
  text       String
  isCorrect  Boolean @default(false)
  questionId String
  order      Int

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)
}

// ─── Session (per learner per study condition) ────────────────────────────────

model Session {
  id              String            @id @default(cuid())
  userId          String
  quizId          String
  condition       String            @default("adaptive") // "adaptive" | "static"
  startedAt       DateTime          @default(now())
  state           UserSessionState?
  analyticsEvents AnalyticsEvent[]
  completedAt     DateTime?

  // Optional link to the assessment (pre-test) that seeded this session's
  // initial theta and BKT priors. When set, the learner demonstrated ability
  // in the pre-test and the engine started above the novice default.
  startedFromAssessmentId String?

  // IRT learner state, updated after each response via EAP
  theta   Float @default(-0.780) // current ability estimate (self-pilot theta_0)
  thetaSd Float @default(0.543) // posterior standard deviation

  // BKT state stored as JSON, Record<kcId, KCState>
  kcStates String @default("{}") // JSON serialised

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz Quiz @relation(fields: [quizId], references: [id], onDelete: Cascade)

  interactions Interaction[]
  assessments  Assessment[]

  kcMasteries           KCMastery[]
  variantPresentations  VariantPresentation[]
  confidenceCalibration ConfidenceCalibration?
  sessionSummary        SessionSummary?

  @@index([userId])
  @@index([quizId])
}

// ─── Interaction (single Q&A event) ──────────────────────────────────────────

model Interaction {
  id             String  @id @default(cuid())
  sessionId      String
  questionId     String
  selectedAnswer String // option label: "A", "B", "C", or "D"
  isCorrect      Boolean
  responseTimeMs Int // milliseconds

  // IRT state before and after this response
  theta_before Float
  theta_after  Float

  // BKT state for the question's KC before and after
  pLearned_before Float
  pLearned_after  Float

  // Cognitive load rating (NASA-TLX style): 1=Very easy, 5=Very difficult
  cognitiveLoad Int?

  // Hint usage tracking for graduated mastery penalty (Koedinger & Aleven, 2007)
  hintsUsed    Int @default(0) // total hints revealed before answering
  hintLevelMax Int @default(0) // highest hint level used (1=conceptual, 2=procedural, 3=worked example)

  createdAt DateTime @default(now())

  session  Session  @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
  @@index([questionId])
}

// ─── Assessment (pre/post/delayed test) ──────────────────────────────────────

model Assessment {
  id          String    @id @default(cuid())
  userId      String
  sessionId   String?
  quizId      String
  type        String    @default("post_test") // pre_test | post_test | delayed_post_test
  startedAt   DateTime  @default(now())
  completedAt DateTime?
  score       Float? // raw score (correct / total)
  maxScore    Float?
  passed      Boolean   @default(false)
  thetaAtTime Float? // IRT ability estimate at time of assessment

  user    User     @relation(fields: [userId], references: [id], onDelete: Cascade)
  quiz    Quiz     @relation(fields: [quizId], references: [id], onDelete: Cascade)
  session Session? @relation(fields: [sessionId], references: [id])
  answers Answer[]

  @@index([userId])
  @@index([sessionId])
  @@index([quizId])
}

model Answer {
  id               String   @id @default(cuid())
  assessmentId     String
  questionId       String
  selectedOptionId String?
  textAnswer       String?
  isCorrect        Boolean?
  createdAt        DateTime @default(now())

  assessment Assessment @relation(fields: [assessmentId], references: [id], onDelete: Cascade)
  question   Question   @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([assessmentId])
  @@index([questionId])
}

// ─── Progress / Badges ────────────────────────────────────────────────────────

model UserProgress {
  id        String   @id @default(cuid())
  userId    String
  topicId   String
  accuracy  Float    @default(0)
  completed Boolean  @default(false)
  updatedAt DateTime @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, topicId])
}

model Badge {
  id          String   @id @default(cuid())
  name        String
  description String?
  icon        String?
  criteria    String
  createdAt   DateTime @default(now())

  users UserBadge[]
}

model UserBadge {
  id       String   @id @default(cuid())
  userId   String
  badgeId  String
  earnedAt DateTime @default(now())

  user  User  @relation(fields: [userId], references: [id], onDelete: Cascade)
  badge Badge @relation(fields: [badgeId], references: [id], onDelete: Cascade)

  @@unique([userId, badgeId])
}

model SystemLog {
  id        String   @id @default(cuid())
  action    String
  userId    String?
  details   String?
  timestamp DateTime @default(now())
}

// ============================================
// PATH B: INSTRUCTIONAL CONTENT LAYER
// Added: 2026-03-09
// Purpose: Transform from assessment-only to ITS
// Decision: ADR-005
// ============================================

// --- Knowledge Component (explicit model for KC tracking) -------------------

model KnowledgeComponent {
  id          String  @id // Use the kc string as ID (e.g., "UK_capitals")
  name        String
  description String?
  bloomLevel  Int     @default(1) // 1, 2, or 3

  createdAt DateTime @default(now())

  // Relations
  learningObjects LearningObject[]
  prerequisiteFor PrerequisiteEdge[] @relation("KCPrerequisites")
  dependentOn     PrerequisiteEdge[] @relation("KCDependents")

  kcMasteries       KCMastery[]
  questionTemplates QuestionTemplate[]
}

// --- Learning Object (instructional content chunks) -------------------------

model LearningObject {
  id          String  @id @default(cuid())
  title       String
  content     String  @db.Text // Markdown instructional content
  eli5Content String? @db.Text // Simplified "Explain Like I'm 5" version
  contentType String  @default("text") // text, diagram, video
  bloomLevel  Int // 1 = Remembering, 2 = Understanding, 3 = Applying
  orderIndex  Int // Sequencing within KC

  knowledgeComponentId String
  knowledgeComponent   KnowledgeComponent @relation(fields: [knowledgeComponentId], references: [id])

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt
}

// --- Hint (graduated scaffolding per question) ------------------------------

model Hint {
  id         String @id @default(cuid())
  hintText   String @db.Text
  hintLevel  Int // 1 = conceptual, 2 = procedural, 3 = worked example
  orderIndex Int

  questionId String
  question   Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// --- Prerequisite Edge (KC dependency graph) --------------------------------

model PrerequisiteEdge {
  id               String @id @default(cuid())
  masteryThreshold Float  @default(0.8) // Required P(L) to unlock dependent KC

  fromKCId String // Prerequisite KC
  toKCId   String // Dependent KC (unlocked when fromKC mastered)

  fromKC KnowledgeComponent @relation("KCPrerequisites", fields: [fromKCId], references: [id])
  toKC   KnowledgeComponent @relation("KCDependents", fields: [toKCId], references: [id])

  @@unique([fromKCId, toKCId])
}

// --- User Session State (mode tracking for ITS) -----------------------------

model UserSessionState {
  id                String  @id @default(cuid())
  currentMode       String  @default("assessing") // assessing, instructing, practicing, remediating
  currentKCId       String? // Which KC user is currently working on
  consecutiveFails  Int     @default(0)
  interventionCount Int     @default(0) // Times system switched to instruction
  scaffoldRequests  Int     @default(0) // Times user clicked "Review Material"
  hintsUsed         Int     @default(0) // Total hints revealed

  sessionId String  @unique
  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt
}

// --- Analytics Event (detailed logging for dissertation) --------------------

model AnalyticsEvent {
  id        String   @id @default(cuid())
  eventType String // MODE_CHANGE, HINT_REQUESTED, CONTENT_VIEWED, THETA_UPDATED, etc.
  payload   Json // Flexible event data
  timestamp DateTime @default(now())

  sessionId String
  session   Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([sessionId])
}

// ============================================
// ADAPTIVE ENGINE EXTENSIONS
// Added: 2026-03-12
// Purpose: 5 evidence-based learning mechanics
// ============================================

// --- KC Mastery (Successive Relearning / Nemesis System) -------------------

model KCMastery {
  id        String @id @default(cuid())
  sessionId String
  kcId      String

  pLearned Float @default(0.5)
  pForget  Float @default(0.05)

  lastAssessedAt DateTime  @default(now())
  masteredAt     DateTime?
  decayedAt      DateTime?

  relearningCount    Int @default(0)
  totalPresentations Int @default(0)

  session Session            @relation(fields: [sessionId], references: [id], onDelete: Cascade)
  kc      KnowledgeComponent @relation(fields: [kcId], references: [id], onDelete: Cascade)

  @@unique([sessionId, kcId])
  @@index([kcId])
  @@index([sessionId])
}

// --- Question Template (Isomorphic Variation) ------------------------------

model QuestionTemplate {
  id           String @id @default(cuid())
  templateText String @db.Text

  difficulty     Float @default(0.0)
  discrimination Float @default(1.0)
  guessingParam  Float @default(0.25)

  bloomLevel Int    @default(1)
  kcId       String

  supportsMC       Boolean @default(true)
  supportsCloze    Boolean @default(false)
  supportsFreeText Boolean @default(false)

  kc       KnowledgeComponent @relation(fields: [kcId], references: [id], onDelete: Cascade)
  variants QuestionVariant[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  @@index([kcId])
  @@index([bloomLevel])
}

model QuestionVariant {
  id         String @id @default(cuid())
  templateId String

  variables       Json
  correctAnswer   String
  acceptedAnswers Json?
  distractors     Json
  clozeTemplate   String? @db.Text

  template      QuestionTemplate      @relation(fields: [templateId], references: [id], onDelete: Cascade)
  presentations VariantPresentation[]
  seenBy        UserVariantSeen[]

  @@index([templateId])
}

model VariantPresentation {
  id        String @id @default(cuid())
  variantId String
  sessionId String

  presentedAt DateTime @default(now())
  format      String   @default("mc")

  isCorrect       Boolean?
  confidenceLevel Int?
  responseTimeMs  Int?

  variant QuestionVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)
  session Session         @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  @@index([variantId])
  @@index([sessionId])
  @@index([presentedAt])
}

// --- Confidence Calibration (CBM) ------------------------------------------

model ConfidenceCalibration {
  id        String @id @default(cuid())
  sessionId String @unique

  highConfCorrect Int @default(0)
  highConfWrong   Int @default(0)
  lowConfCorrect  Int @default(0)
  lowConfWrong    Int @default(0)

  calibrationScore Float?

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  updatedAt DateTime @updatedAt
}

// --- Session Summary (Self-Referenced Feedback) ----------------------------

model SessionSummary {
  id        String @id @default(cuid())
  sessionId String @unique

  totalQuestions Int    @default(0)
  correctAnswers Int    @default(0)
  accuracy       Float?

  kcDeltas Json?

  avgMasteryStart Float?
  avgMasteryEnd   Float?
  netImprovement  Float?

  itemsRelearned Int @default(0)

  session Session @relation(fields: [sessionId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())
}

// --- Study Schedule (spaced repetition reminders, features 1 & 4) -----

model StudySchedule {
  id        String   @id @default(cuid())
  userId    String
  sessionId String   // session that generated this schedule
  kcId      String   // which KC to review
  dueAt     DateTime // when the review is due
  interval  Int      @default(1) // days until next review (1, 3, 7, 14, 30)
  completed Boolean  @default(false)
  completedAt DateTime?
  skipped   Boolean  @default(false)

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now())

  @@index([userId])
  @@index([dueAt])
  @@index([userId, completed])
}

// --- Learner Goal (adaptive goal setting, feature 9) ------------------

model LearnerGoal {
  id            String   @id @default(cuid())
  userId        String
  goalType      String   // "mastery_count" | "accuracy" | "streak"
  targetValue   Float    // e.g. 6 (KCs to master) or 0.85 (accuracy)
  currentValue  Float    @default(0)
  achieved      Boolean  @default(false)
  achievedAt    DateTime?
  expiresAt     DateTime? // optional deadline
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
}

// --- Elaborative Interrogation (self-explanation prompts, feature 6) ---

model ElaborationResponse {
  id            String   @id @default(cuid())
  userId        String
  sessionId     String
  questionId    String   // which question prompted the elaboration
  kcId          String
  prompt        String   // the "why" question asked
  response      String   @db.Text // learner's free-text explanation
  responseTimeMs Int?    // how long they spent writing
  createdAt     DateTime @default(now())

  @@index([userId])
  @@index([sessionId])
  @@index([kcId])
}

// --- Research Consent & Data Export (human tester data collection) -----

model ResearchConsent {
  id            String   @id @default(cuid())
  userId        String   @unique
  consentGiven  Boolean  @default(false)
  consentDate   DateTime?
  participantId String?  // anonymised participant code (P01, P02, etc.)
  ageRange      String?  // "18-24", "25-34", etc.
  priorGeoKnowledge String? // "none", "gcse", "a-level", "degree"
  createdAt     DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)
}

// --- SUS Questionnaire Response (System Usability Scale) ----------------

model SUSResponse {
  id        String @id @default(cuid())
  userId    String
  q1  Int // I think I would like to use this system frequently (1-5)
  q2  Int // I found the system unnecessarily complex
  q3  Int // I thought the system was easy to use
  q4  Int // I think I would need technical support
  q5  Int // I found the various functions well integrated
  q6  Int // I thought there was too much inconsistency
  q7  Int // I imagine most people would learn to use this quickly
  q8  Int // I found the system very cumbersome
  q9  Int // I felt very confident using the system
  q10 Int // I needed to learn a lot before I could get going
  susScore Float? // calculated SUS score (0-100)
  createdAt DateTime @default(now())

  @@index([userId])
}

// --- User Variant Seen (cross-session deduplication) ------------------

model UserVariantSeen {
  id          String   @id @default(cuid())
  userId      String
  variantId   String
  firstSeenAt DateTime @default(now())

  user    User            @relation(fields: [userId], references: [id], onDelete: Cascade)
  variant QuestionVariant @relation(fields: [variantId], references: [id], onDelete: Cascade)

  @@unique([userId, variantId])
  @@index([userId])
  @@index([variantId])
}
